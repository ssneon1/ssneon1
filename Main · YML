name: GitHub Stats
on:
  schedule:
    # Runs once a day at midnight UTC. Change the cron value if you want a different schedule.
    - cron: "0 0 * * *"
  workflow_dispatch: {}   # lets you trigger it manually from the Actions tab
  push:
    branches:
      - master
      - main

jobs:
  build:
    runs-on: ubuntu-latest
    permissions:
      contents: write
    name: Generate GitHub stats images
    steps:
      - name: Generate stats
        uses: jstrieb/github-stats@master
        with:
          username: ssneon1
          access_token: ${{ secrets.ACCESS_TOKEN }}
